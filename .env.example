# Prisma / SQLite
DATABASE_URL="file:./prisma/dev.db"

# Gmail (Google Cloud OAuth client — Desktop app type works for the CLI flow)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost"

# Where to store downloaded attachments (PDFs etc). Defaults to ./storage.
STORAGE_DIR="./storage"

# Optional: pin a Gmail account. If unset, the most recently authorized
# account in the IntegrationAccount table is used.
# GMAIL_ACCOUNT_KEY=""

# Telegram (BotFather token + default chat target)
TELEGRAM_ASSISTANT_BOT_TOKEN=""
# Discover with: pnpm telegram:get-chat-id (after sending any message to your bot).
# For a forum supergroup, use the negative chat id of the group itself.
TELEGRAM_DEFAULT_CHAT_ID=""
# Optional: name → thread_id map for forum topics. Surfaced in agent
# system prompts so the LLM can route signals into the right topic.
# Example: TELEGRAM_TOPICS_JSON='{"bills":42,"bank":43,"chat":1}'
# TELEGRAM_TOPICS_JSON=""

# Telegram userbot (gramjs / MTProto) — for reading channels the user is
# subscribed to with their own account. Get app credentials at
# https://my.telegram.org → "API development tools".
# Run `pnpm userbot:auth` once after setting these to do the phone+code
# login flow (session string is stored in tokens.db, kept across restarts).
# The agent discovers subscribed channels at runtime via list_userbot_dialogs —
# no static channel list needed.
TELEGRAM_APP_ID=""
TELEGRAM_APP_API_HASH=""

# Monobank personal token — issue at https://api.monobank.ua/
MONOBANK_API_KEY=""

# DeepSeek (OpenAI-compatible API). Used by the custom agent loop.
DEEPSEEK_API_KEY=""
# Optional: override the model used by packages/agent/src/loop.ts
# AGENT_MODEL="deepseek-chat"

# Hour (local time, 0-23) at which the daily tech-digest signal fires
# (HN/Habr IT news). Default 9.
# TECH_DIGEST_HOUR="9"

# Hour (local time, 0-23) at which the daily news-digest signal fires
# (curated topical news — Odessa / PMR / RU-UA / World — filtered from
# Telegram channel posts via gramjs userbot). Default 9.
# NEWS_DIGEST_HOUR="9"

# Hour (local time, 0-23) at which the daily dreaming reflection fires.
# Default 4 (quiet pre-dawn time).
# DREAMING_HOUR="4"
# Optional: model used for dreaming sessions (overrides AGENT_MODEL only
# for source=dreaming). Defaults to deepseek-reasoner — thinking-tier is
# worth the cost for free-form skill-editing reasoning.
# DREAMING_MODEL="deepseek-reasoner"
