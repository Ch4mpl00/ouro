# LLM providers (required)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional per-preset model overrides — use the `provider:model` form.
# AGENT_BASE_MODEL=openai:gpt-5.4-mini
# AGENT_SMART_MODEL=deepseek:deepseek-v4-pro
# AGENT_SMARTEST_MODEL=openai:gpt-5.4

# MCP transport: http (default) | stdio
MCP_TRANSPORT=http
# http:
MCP_URL=http://localhost:3000/mcp
# stdio (spawns `pnpm mcp:serve`): the mcp-tools monorepo root
# MCP_PROJECT_ROOT=/Users/dimas/Code/mcp-tools

USER_EMAIL=

# Tracing (optional). LangSmith — just set the env vars:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=agent-py
# Langfuse:
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
