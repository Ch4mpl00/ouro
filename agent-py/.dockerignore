# The Dockerfile COPYs only what it needs (pyproject, uv.lock, agent_py,
# scripts, skills.default) — this is the safety net so runtime state and
# secrets never enter the build context even if that changes.

.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Runtime state — lives in named volumes, never baked into the image.
data/
skills/

# Secrets — come from env_file at runtime.
.env
.env.*

# VCS / editor / docs not needed at runtime.
.git/
.gitignore
.claude/
.idea/
.vscode/
README.md
