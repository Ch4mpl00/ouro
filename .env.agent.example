# Agent container env. Contains ONLY the LLM credential and model config —
# no integration secrets reach this container. Copy to .env.agent and fill.

# DeepSeek API key (https://platform.deepseek.com).
DEEPSEEK_API_KEY=""

# Optional: override the default model used for most sessions.
# AGENT_MODEL="deepseek-v4-pro"

# Optional: model used specifically for `dreaming` sessions (heavier
# reasoning). Defaults to deepseek-reasoner.
# DREAMING_MODEL="deepseek-reasoner"

# Langfuse observability (https://cloud.langfuse.com → Settings → API Keys).
# Leave all three empty to disable tracing — the agent works fine without it.
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_BASE_URL="https://cloud.langfuse.com"
