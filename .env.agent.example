# Agent container env. Contains ONLY the LLM credential and model config —
# no integration secrets reach this container. Copy to .env.agent and fill.

# DeepSeek API key (https://platform.deepseek.com).
# Used for thinking-mode sessions (sub-agents with reasoning_effort=max).
DEEPSEEK_API_KEY=""

# OpenAI API key (https://platform.openai.com).
# Used for non-thinking sessions (the default — telegram replies,
# scheduler dispatch, recovery, etc.).
OPENAI_API_KEY=""

# Gemini API key (https://aistudio.google.com/apikey).
# Used by the WORKFLOW COMPILER (the `compiler` preset, gemini-3-flash-preview)
# via Gemini's OpenAI-compatible endpoint. Required — the compiler is on the hot
# path. A billing-enabled key is recommended; the free tier rate-limits hard
# (the Gemini provider retries 429/5xx, but the quota still has to allow it).
GEMINI_API_KEY=""

# Optional: override the `base` preset model (cheap non-thinking chat).
# Routed to OpenAI when the name starts with anything other than "deepseek".
# AGENT_BASE_MODEL="gpt-5.4-mini"

# Optional: override the `smart` preset model (thinking-mode sub-agents).
# Routed to DeepSeek when the name starts with "deepseek".
# AGENT_SMART_MODEL="deepseek-v4-pro"

# Optional: override the `smartest` preset model (reserve high-end preset for
# sub-agents / handoff). Strict structured-output is most reliable on OpenAI;
# keep this a non-"deepseek", non-"gemini" model.
# AGENT_SMARTEST_MODEL="gpt-5.4"

# Optional: override the `compiler` preset model (the workflow compiler).
# Routing follows the name: "gemini-*" → Gemini, "deepseek-*" → DeepSeek,
# else → OpenAI. gemini-3.5-flash (pricier, equally good) or gpt-5.4 are safe
# fallbacks if the preview model misbehaves.
# AGENT_COMPILER_MODEL="gemini-3-flash-preview"

# Langfuse observability (https://cloud.langfuse.com → Settings → API Keys).
# Leave all three empty to disable tracing — the agent works fine without it.
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# Generic Codex service (docker-compose service name by default).
# The codex container persists auth in the codex-home volume; bootstrap once with:
#   docker compose run --rm codex codex login --device-auth
# CODEX_URL="http://codex:3010"

# Online judge worker. Defaults to Codex and dry-run score writes.
# Set JUDGE_WRITE_SCORES=true after confirming dry-run output.
# JUDGE_PROVIDER="codex"
# JUDGE_RECENT_LIMIT="20"
# JUDGE_POLL_INTERVAL_MS="60000"
# JUDGE_MIN_TRACE_AGE_MS="600000"
# JUDGE_WRITE_SCORES="false"
# JUDGE_ONCE="false"
# CODEX_JUDGE_TIMEOUT_MS="600000"
