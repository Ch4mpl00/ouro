# MCP container env. Holds ALL integration credentials — the agent container
# never sees these. Copy to .env.mcp and fill in.

# Where to store downloaded Gmail attachments inside the container.
# Mounted from named volume mcp-storage. Default is fine.
STORAGE_DIR=/app/storage

# --- Gmail (Google Cloud OAuth client, Desktop app type) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost"
# Optional: pin to a specific Gmail account; otherwise the most-recently
# authorized one in integration_account is used.
# GMAIL_ACCOUNT_KEY=""

# --- Telegram bot (BotFather) ---
TELEGRAM_ASSISTANT_BOT_TOKEN=""
TELEGRAM_DEFAULT_CHAT_ID=""
# Optional: forum topics map (name → thread_id) injected into agent prompts.
# TELEGRAM_TOPICS_JSON='{"bills":42}'

# --- Telegram userbot (gramjs / MTProto) ---
# From https://my.telegram.org → API development tools.
# Run `pnpm userbot:auth` once inside the mcp container (or before deploy)
# to do the phone + code login; session string is stored in tokens.db.
TELEGRAM_APP_ID=""
TELEGRAM_APP_API_HASH=""

# --- Monobank personal token ---
MONOBANK_API_KEY=""

# --- Cron hours (local time, 0-23). Defaults shown. ---
# TECH_DIGEST_HOUR="9"
# NEWS_DIGEST_HOUR="9"
# DREAMING_HOUR="4"
