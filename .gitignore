/skills/

# Generated SQLite databases (schema.sql is the source of truth)
packages/*/data/*.db
packages/*/data/*.db-journal
packages/*/data/*.db-wal
packages/*/data/*.db-shm

# OS / editor
.DS_Store
.idea/
.vscode/

# Claude Code runtime artefacts (we commit .claude/tasks/* by hand,
# but not lock files / session state).
.claude/scheduled_tasks.lock
.claude/projects/
