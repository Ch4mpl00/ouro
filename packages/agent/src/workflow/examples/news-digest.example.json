{
  "version": 1,
  "steps": [
    {
      "kind": "parallel",
      "steps": [
        {
          "kind": "tool",
          "tool": "list_news",
          "args": {
            "source": "channel",
            "sinceISO": "${env.watermark}"
          },
          "bind": "posts"
        },
        {
          "kind": "tool",
          "tool": "get_telegram_chat_history",
          "args": {
            "chatId": "${env.chatId}",
            "limit": 5
          },
          "bind": "history"
        }
      ]
    },
    {
      "kind": "llm_compose",
      "preset": "smart",
      "skill": "news-digest",
      "input": {
        "posts": "${posts}",
        "history": "${history}",
        "date": "${env.date}",
        "timezone": "${env.timezone}"
      },
      "bind": "digest"
    },
    {
      "kind": "parallel",
      "steps": [
        {
          "kind": "tool",
          "tool": "send_telegram_message",
          "args": {
            "chatId": "${env.chatId}",
            "text": "${digest}"
          }
        },
        {
          "kind": "tool",
          "tool": "set_memory",
          "args": {
            "key": "news_digest.last_read_at",
            "value": "${env.now}"
          }
        }
      ]
    },
    {
      "kind": "terminal"
    }
  ]
}
